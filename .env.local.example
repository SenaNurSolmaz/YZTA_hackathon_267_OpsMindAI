# Bu dosyayi kopyalayip ".env.local" olarak kaydedin
# ve asagidaki degerleri doldurun.

# --- Gemini AI ---
GEMINI_API_KEY=buraya_gemini_api_key_yaz
GEMINI_MODEL=gemini-3-flash-preview

# --- Slack Webhook (opsiyonel - yoksa simulasyon modu) ---
SLACK_SUPPLY_WEBHOOK_URL=
SLACK_NOTIFY_WEBHOOK_URL=

# --- WhatsApp Business API (opsiyonel - yoksa simulasyon modu) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_NOTIFY_NUMBER=

# --- Veritabani ---
# PostgreSQL sifrenizi girin (kurulumda belirlediginiz sifre)
DATABASE_URL=postgresql://postgres:SIFRENIZI_YAZIN@localhost:5432/techops_db

# --- NextAuth (degistirmeye gerek yok) ---
NEXTAUTH_SECRET=en_az_32_karakter_rastgele_deger
NEXTAUTH_URL=http://localhost:3000